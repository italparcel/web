# Copy to .env.local and fill in — see README.md for details.

# Resend (email delivery). In development, submissions are logged to stdout
# when unset; in production the contact endpoint returns 500 without it.
RESEND_API_KEY=

# Cloudflare Turnstile. REQUIRED in production: the contact endpoint
# hard-fails (500) if the secret is missing. Optional in development —
# the captcha is skipped when unset so the local form still works.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional — defaults shown.
# CONTACT_EMAIL=contact@italparcel.com
# FROM_EMAIL="ItalParcel <onboarding@resend.dev>"
